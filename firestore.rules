rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // All authenticated users can read any collection
    // Writes are open to authenticated users (role enforcement is in the app)
    match /{collection}/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
